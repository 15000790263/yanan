{
  "name": "kel-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "cordova build android",
    "build-debugger": "vite build --mode development && node modify-build.js && cordova build android",
    "build-release": "vite build && node modify-build.js && cordova build android --release",
    "build-emulato": "vite build && node modify-build.js --mode development && cordova run --emulator --target=192.168.56.101:5555",
    "build-device": "vite build && node modify-build.js && cordova run --device",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "emu": "cordova run --emulator"
  },
  "dependencies": {
    "@antv/x6": "^2.16.1",
    "@antv/x6-plugin-scroller": "^2.0.10",
    "@popperjs/core": "^2.11.8",
    "@turf/turf": "^7.2.0",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "axios": "^1.6.0",
    "cesium": "^1.120.0",
    "coordtransform": "^2.1.2",
    "core-js": "^3.39.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.1",
    "emittery": "^1.0.3",
    "fast-xml-parser": "^4.3.2",
    "geolib": "^3.3.4",
    "hammerjs": "^2.0.8",
    "html5-qrcode": "^2.3.8",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "leaflet-polylinedecorator": "^1.6.0",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "overlayscrollbars": "^2.8.0",
    "overlayscrollbars-vue": "^0.5.6",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "recordrtc": "^5.6.2",
    "unplugin-auto-import": "^0.17.6",
    "uuid": "^9.0.1",
    "v-calendar": "^3.1.2",
    "vant": "^4.9.24",
    "vite-plugin-cesium": "^1.2.22",
